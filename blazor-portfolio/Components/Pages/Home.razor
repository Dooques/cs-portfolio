@page "/"
@using blazor_portfolio.Components.Home
<PageTitle>Dooques: Software Developer</PageTitle>

<ContactModal @ref="ModalRef"/>

<Column>
    <BioHeader/>
    
    <TechStackIcons/>
    
    <Divider Border="Border.Dark"/>
    
    <HangulizerProject/>
    
    <MoreProjects ShowModal="@ShowModal"/>
</Column>

@code {

    private ContactModal ModalRef { get; set; } = new();

    private async Task ShowModal()
    {
        await ModalRef.ShowContactModal();
    }

    private async Task HideModal()
    {
        await ModalRef.CloseContactModal();
    }
}