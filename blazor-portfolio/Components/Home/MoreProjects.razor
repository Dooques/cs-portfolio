<Row Flex="Flex.Row.JustifyContent.Start"
     Gap="Gap.Is5"
     Margin="Margin.Is1.OnX">
    <Button Type="ButtonType.Link"
            Color="Color.Secondary"
            To="projects"
            Width="Width.Is25">
       More Projects 
    </Button>

    <Button Type="ButtonType.Button"
            Color="Color.Secondary"
            Width="Width.Is25"
            Clicked="@HandleModalEvent">
        Contact
    </Button>
</Row>

@code {
    [Parameter] public EventCallback ShowModal { get; set; }

    private async Task HandleModalEvent()
    {
        if (ShowModal.HasDelegate)
        {
            await ShowModal.InvokeAsync();
        }
    }
}