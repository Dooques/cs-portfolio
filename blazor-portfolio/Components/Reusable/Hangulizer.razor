<Div Flex="Flex.Column.JustifyContent.Center.AlignItems.Start" Margin="Margin.Is4.OnX">
    <Heading3>
        Hangulizer
    </Heading3>
    
    <Paragraph>
        This project is a console application that translates Korean characters into english phonetics.
    </Paragraph>
    
    <Fields ColumnSize="ColumnSize.IsAuto">
        <Field>
            <FieldLabel>Translate the hangul characters!</FieldLabel>
            <FieldBody>
                <MemoInput Placeholder="Type korean characters here..."/>
            </FieldBody>
        </Field>

        <Button Margin="Margin.Is2.OnY"
                Color="Color.Primary"
                Clicked="@handleClick">
            Translate Now
        </Button>

        <Field>
            <FieldLabel for="hangulizer">Results!</FieldLabel>
            <MemoInput Rows="2"
                       ReadOnly="true" 
                       Value="@TranslatedText"
                       AutoSize/>
        </Field>
    </Fields>
</Div>

@code {
    private string HangulText { get; set; } = "";
    private string TranslatedText { get; set; } = "";

    private void handleClick()
    {
        return;
    }

}