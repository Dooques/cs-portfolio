@page "/"
@using blazor_portfolio.Components.Home
<PageTitle>Dooques: Software Developer</PageTitle>

<Modal @ref="@ContactModal" Centered>
    <ModalContent>
        <ModalHeader>
            <ModalTitle>
                Get in Touch
            </ModalTitle>
            <CloseButton/>
        </ModalHeader>
        <ModalBody>
            <Column Padding="Padding.Is2.OnX">
                <Row Flex="Flex.JustifyContent.Center.AlignItems.Center"
                     Margin="Margin.Is3.FromBottom">
                    <Figure Size="FigureSize.Is32x32"
                            Padding="Padding.Is0"
                            Margin="Margin.Is0">
                        <Image Source="img/email.png" Fluid="true"
                               Style="height: 32px; width: auto; filter: brightness(0) saturate(100%) invert(37%) sepia(93%) saturate(5470%) hue-rotate(214deg) brightness(101%) contrast(99%);"/>
                    </Figure>

                    <Column Margin="Margin.Is2.FromStart">
                        <Heading Size="HeadingSize.Is6"
                                 TextColor="TextColor.Muted"
                                 TextWeight="TextWeight.Bold">
                            samuel@dooques.uk
                        </Heading>
                    </Column>
                </Row>

                <Row Flex="Flex.JustifyContent.Center.AlignItems.Center"
                     Margin="Margin.Is3.OnY">
                    <Figure Size="FigureSize.Is32x32"
                            Padding="Padding.Is0"
                            Margin="Margin.Is0">
                        <Image Source="img/linkedin.png" Fluid="true"/>
                    </Figure>

                    <Column Margin="Margin.Is2.FromStart">
                        <Anchor To="https://linkedin.com/in/dooques"
                                TextColor="TextColor.Muted"
                                TextDecoration="TextDecoration.None">
                            <Heading Size="HeadingSize.Is6"
                                     Class="mb-1 fw-bold">
                                LinkedIn
                            </Heading>
                        </Anchor>
                    </Column>
                </Row>

                <Row Flex="Flex.JustifyContent.Center.AlignItems.Center"
                     Margin="Margin.Is3.OnY">
                    <Figure Size="FigureSize.Is32x32"
                            Padding="Padding.Is0"
                            Margin="Margin.Is0">
                        <Image Source="img/github.png" Fluid="true"/>
                    </Figure>

                    <Column Margin="Margin.Is2.FromStart">

                        <Anchor To="https://github.com/dooques"
                                TextColor="TextColor.Muted"
                                TextDecoration="TextDecoration.None">
                            <Heading Size="HeadingSize.Is6"
                                     Class="mb-1 fw-bold">
                                GitHub
                            </Heading>
                        </Anchor>
                    </Column>
                </Row>
            </Column>
        </ModalBody>
    </ModalContent>
</Modal>

<Container Breakpoint="Breakpoint.Desktop">
    <BioHeader/>
    
    <TechStackIcons/>
    
    <Divider Border="Border.Dark"/>
    
    <HangulizerProject/>
    
    <Divider Border="Border.Dark"/>
    
    <MoreProjects ShowModal="ShowModal"/>
</Container>

@code {
    private Modal ContactModal;

    public async Task ShowModal()
    {
        ContactModal.Show();
    }

    private async Task HideModal()
    {
        ContactModal.Hide();
    }
}