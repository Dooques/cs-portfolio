@using blazor_portfolio.Components.Pages
<Blazorise.ThemeProvider Theme="@_theme">
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <RouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)"/>
            <FocusOnNavigate RouteData="routeData" Selector="h1"/>
        </Found>
        
        <NotFound>
            <LayoutView>
                <NotFound />
            </LayoutView>
        </NotFound>
    </Router>
</Blazorise.ThemeProvider>


@code {

    private readonly Theme _theme = new Theme
    {
        ColorOptions = new ThemeColorOptions
        {
            Primary = "#6E1F3B",   // burgundy – buttons, links, CTAs
            Secondary = "#8B4226", // auburn – secondary actions
            Info = "#AEB9F2",      // periwinkle – your highlight color
            Dark = "#2A1B12",      // dark ink – headings/text
            Light = "#F1E8D9"      // cream – light surfaces, subtle backgrounds
        },
        BackgroundOptions = new ThemeBackgroundOptions
        {
            Primary = "#6E1F3B",   // burgundy – buttons, links, CTAs
            Secondary = "#8B4226", // auburn – secondary actions
            Info = "#AEB9F2",      // periwinkle – your highlight color
            Dark = "#2A1B12",      // dark ink – headings/text
            Light = "#F1E8D9"  
        },
        TextColorOptions = new ThemeTextColorOptions
        {
            Primary = "#6E1F3B",   // burgundy – buttons, links, CTAs
            Secondary = "#8B4226", // auburn – secondary actions
            Info = "#AEB9F2",      // periwinkle – your highlight color
            Dark = "#2A1B12",      // dark ink – headings/text
            Light = "#F1E8D9"  
        }
    };
}